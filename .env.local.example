# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_ENDPOINT=http://localhost:3000
NEXT_PUBLIC_PROD_API_ENDPOINT=https://your-app.vercel.app

# ── Database (Neon) ───────────────────────────────────────────────────────────
# From: neon.tech → your project → Connection string
DATABASE_URL=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── ImageKit ─────────────────────────────────────────────────────────────────
# From: imagekit.io → Developer → API keys
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# From: upstash.com → Redis → your database → REST API
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Upstash QStash (Workflows) ────────────────────────────────────────────────
# From: upstash.com → QStash → API Keys
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=

# ── Resend (Email) ────────────────────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_TOKEN=
